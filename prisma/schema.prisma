// Aivora – Prisma Schema
// Supabase (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

enum SettingsLanguage {
  EN
  TR
}

// ─── Models ─────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users         User[]
  userSettings  UserSettings[]
  prdTasks      PrdTask[]
  documents     Document[]
  conversations Conversation[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String?  @map("full_name")
  password  String
  role      Role     @default(USER)
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  settings UserSettings?

  @@index([tenantId])
  @@map("users")
}

model UserSettings {
  id                 String           @id @default(uuid())
  userId             String           @unique @map("user_id")
  tenantId           String           @map("tenant_id")
  themePreference    ThemePreference  @default(SYSTEM) @map("theme_preference")
  language           SettingsLanguage @default(TR)
  timezone           String           @default("Europe/Istanbul")
  emailNotifications Boolean          @default(true) @map("email_notifications")
  inAppNotifications Boolean          @default(true) @map("in_app_notifications")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("user_settings")
}

// ─── PRD Tracker ────────────────────────────────────────

enum TaskStatus {
  PENDING
  TODO
  IN_PROGRESS
  BLOCKED
  REVIEW
  COMPLETED
  DONE
}

model PrdTask {
  id        String     @id @default(uuid())
  title     String
  module    String     // e.g., auth, rag, chat
  status    TaskStatus @default(TODO)
  tenantId  String     @map("tenant_id")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("prd_tasks")
}

// ─── Knowledge Base ───────────────────────────────────────

model Document {
  id        String   @id @default(uuid())
  title     String
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  chunks DocumentChunk[]
  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("documents")
}

model DocumentChunk {
  id          String   @id @default(uuid())
  documentId  String   @map("document_id")
  content     String
  embeddingId String   @map("embedding_id") // Qdrant point ID reference

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_chunks")
}

// ─── Chat System ────────────────────────────────────────

model Conversation {
  id        String    @id @default(uuid())
  title     String?
  tenantId  String    @map("tenant_id")
  createdAt DateTime  @default(now()) @map("created_at")

  messages Message[]
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  content        String
  role           String   // "user" or "assistant"
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}
